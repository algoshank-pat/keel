# Copy this file to .env and fill in your values.
# NEVER commit your real .env — it's gitignored.

# --- LLM provider (pick one) ---
OPENAI_API_KEY=sk-...
# AZURE_OPENAI_ENDPOINT=https://<resource>.openai.azure.com/
# AZURE_OPENAI_API_KEY=...

# --- Integration / API Management layer ---
# The endpoint Keel reads partner & order data from
INTEGRATION_API_BASE_URL=https://<your-apim-or-ipaas-endpoint>
INTEGRATION_API_KEY=...

# --- App config ---
MODEL_NAME=gpt-4o-mini
REVENUE_AT_RISK_THRESHOLD=10000   # only alert above this $ impact
RECOMMENDATION_CONFIDENCE_MIN=0.6 # abstain below this; ask a human
LOG_LEVEL=INFO
